# ═══════════════════════════════════════════════════
# FLUENTBUDDY - Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Supabase (get from supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key-here

# Supabase Service Role Key (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-secret-key-here

# Claude API Key (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# App URL (update to your Vercel domain after deploying)
NEXT_PUBLIC_APP_URL=http://localhost:3000
